{
  "name": "cluedo-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
