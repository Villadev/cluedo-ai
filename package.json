    "primeicons": "^7.0.0",
    "primeflex": "^3.3.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "typescript": "^5.9.0",
    "zone.js": "~0.15.0"
  }
}
